{
  "manifest_version": 3,
  "name": "Beam",
  "short_name": "Beam",
  "description": "Connect two devices for 2 minutes and beam a photo or link between them.",
  "version": "1.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Beam"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["contextMenus"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["https://www.beamlot.com/app*", "https://beam-wckn2w.fly.dev/app*", "http://localhost:3000/app*"],
      "js": ["content-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
