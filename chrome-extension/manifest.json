{
  "manifest_version": 3,
  "name": "Beam",
  "short_name": "Beam",
  "description": "Connect two devices for 2 minutes and beam a photo or link between them.",
  "version": "1.0.4",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Beam"
  },
  "background": {
    "service_worker": "background.js"
  }
}
