PORT=3000
DB_PATH=./data/relay.sqlite
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_BYTES=15728640
# Comma-separated list of origins allowed to call the relay from a browser
CORS_ORIGIN=http://localhost:5173

# Admin auth — leave unset to disable admin login entirely (fails closed).
# Generate ADMIN_PASSWORD_HASH with: node scripts/hash-admin-password.js '<password>'
# SESSION_SECRET can be any long random string (e.g. `openssl rand -hex 32`).
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
