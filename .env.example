PORT=3000
DB_PATH=./data/relay.sqlite
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_BYTES=15728640
# The URL every pairing link/QR code points at, and the canonical host
# anything else gets redirected to (see relay-server/lib/publicRelayUrl.js
# and index.js). Required in any real deployment -- without it, pairing
# links fall back to http://localhost:3000, which is only correct for
# local dev. Never derived from the incoming request, on purpose.
PUBLIC_RELAY_URL=http://localhost:3000
# Comma-separated list of origins allowed to call the relay from a browser
CORS_ORIGIN=http://localhost:5173
# Rate limit on POST /inbox, the one unauthenticated endpoint (mints a
# fresh pairing + token with no login). Defaults to these same values if
# unset -- see relay-server/index.js.
INBOX_LIMIT_WINDOW_MS=600000
INBOX_LIMIT_PER_WINDOW=200
