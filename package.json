{
  "name": "share-to-pc",
  "private": true,
  "version": "0.6.2",
  "description": "Share links and photos from any device to your PC",
  "workspaces": [
    "relay-server",
    "desktop-app",
    "web-client"
  ],
  "scripts": {
    "dev:relay": "npm run dev -w relay-server",
    "start:relay": "npm run start -w relay-server",
    "test:relay": "npm run test -w relay-server",
    "dev:desktop": "npm run start -w desktop-app",
    "dev:web": "npm run dev -w web-client",
    "build:web": "npm run build -w web-client",
    "build:desktop": "npm run build -w desktop-app"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "electron@32.3.3": true
  }
}
